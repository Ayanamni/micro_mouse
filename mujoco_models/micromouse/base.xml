<mujoco model="micromouse">
  <compiler angle="radian"/>

  <!-- ════════════════════════════════════════════════════════════════════
    物理引擎全局参数
    cone="elliptic": 椭圆锥接触模型，模拟软橡胶胎变形
    impratio=1.5: 最大穿透比
    timestep="2e-5": 物理步长 20µs = 50kHz
    jacobian="dense": 密雅可比矩阵，更精确
    iterations="200": 每步接触求解最大迭代次数
    tolerance="1e-10": 接触求解收敛容差
    ════════════════════════════════════════════════════════════════════ -->
  <option cone="elliptic" impratio="1.5" timestep="2e-5"
          gravity="0 0 -9.81"
          jacobian="dense" iterations="200" tolerance="1e-10"/>

  <default>
    <!-- 接触参数：condim=3 启用扭转摩擦[2]，禁用滚动摩擦[3]（condim=4 的滚动摩擦会锁死偏航） -->
    <!-- solref: [刚度, 阻尼] — 越小越软，0.001=很软 -->
    <!-- solimp: [dmin dmax width mid] — 穿透约束 -->
    <geom condim="3" solref="0.001 0.7" solimp="0.95 0.99 0.0001"/>
    <joint limited="false" armature="1e-7"/>
    <motor ctrlrange="-10 10"/>
  </default>

  <asset>
    <texture name="tex_floor" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.15 0.15 0.15" rgb2="0.25 0.25 0.25"/>
    <material name="mat_floor" texture="tex_floor" texrepeat="10 10" reflectance="0.1"/>
    <material name="mat_chassis" rgba="0.2 0.3 0.8 1"/>
    <material name="mat_wheel" rgba="0.15 0.15 0.15 1"/>
    <material name="mat_caster" rgba="0.5 0.5 0.5 1"/>
    <material name="mat_sensor_bar" rgba="0.1 0.1 0.15 1"/>
    <material name="mat_led" rgba="1 0.15 0.15 1"/>
    <material name="mat_led_dim" rgba="0.4 0.05 0.05 1"/>
  </asset>

  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="3 3 0.001" material="mat_floor"/>

    <!-- ═══════════════════════════════════════════════════════════════
      车身 (Chassis) — 自由体，6自由度
      尺寸: 55mm长(X) × 75mm宽(Y) × 15mm高(Z)
      轮轴 x=0，COM在x=0对齐轮轴，尽可能低 (z=-0.007)
      ═══════════════════════════════════════════════════════════════ -->
    <body name="chassis" pos="0 0 0.012">  <!-- ← 初始离地高度 (m) -->

      <freejoint name="chassis_free"/>

      <!-- ==== 质量 & 惯量：mass=车重(kg) | pos=质心偏移 | diaginertia=Ixx Iyy Izz 转动惯量 (kg·m²) ==== -->
      <inertial mass="0.090" pos="0 0 -0.004"
               diaginertia="4.4e-5 2.4e-5 6.5e-5"/>

      <!-- 车壳：纯视觉，不参与碰撞 (contype/conaffinity=0) -->
      <geom name="chassis_body" type="box" size="0.0275 0.0375 0.0075"
            material="mat_chassis" contype="0" conaffinity="0"/>

      <!-- IMU 安装位置 (轮轴中心) -->
      <site name="imu_site" pos="0 0 0" size="0.002"/>

      <!-- ═══════════════════════════════════════════════════════════
        左驱动轮 — Y=+0.045 (左), Z偏移=-0.0015 (让轮子刚好触地)
        ═══════════════════════════════════════════════════════════ -->
      <!-- 左驱动轮：Y=0.045(轮距/2) | Z=-0.0015(轮心高度) | mass=轮重(kg) -->
      <!-- size=半径(m) 半宽(m) | friction=切向 扭转 滚动摩擦系数 -->
      <body name="wheel_L" pos="0 0.045 -0.0015">
        <joint name="axle_L" type="hinge" axis="0 1 0"/>
        <inertial mass="0.0035" pos="0 0 0"
                 diaginertia="2e-7 3.5e-7 2e-7"/>
        <geom name="wheel_L_geom" type="cylinder" size="0.0105 0.008"
              pos="0 0 0" zaxis="0 1 0" material="mat_wheel"
              friction="1.3 0.08 0.01" priority="1"/>
      </body>

      <!-- ═══════════════════════════════════════════════════════════
        右驱动轮 — Y=-0.045 (右), Z偏移=-0.0015
        ═══════════════════════════════════════════════════════════ -->
      <!-- 右驱动轮：Y=-0.045(轮距/2) | Z=-0.0015(轮心高度) -->
      <body name="wheel_R" pos="0 -0.045 -0.0015">
        <joint name="axle_R" type="hinge" axis="0 1 0"/>
        <inertial mass="0.0035" pos="0 0 0"
                 diaginertia="2e-7 3.5e-7 2e-7"/>
        <geom name="wheel_R_geom" type="cylinder" size="0.0105 0.008"
              pos="0 0 0" zaxis="0 1 0" material="mat_wheel"
              friction="1.3 0.08 0.01" priority="1"/>
      </body>

      <!-- ═══════════════════════════════════════════════════════════
        前后滑板 (Skid) — 防前后翻倒，擦地滑动
        size: X半长 Y半宽 Z半高 (m)
        pos: X前后位置 Y左右 Z高度（相对底盘）
        ═══════════════════════════════════════════════════════════ -->
      <!-- 后滑板：防后翻 | size=半尺寸(m) | pos=X前后 Y左右 Z高度 | friction=切向 扭转 滚动 -->
      <geom name="skid_rear" type="box" size="0.002 0.002 0.0015"
            pos="-0.060 0 -0.01049"
            material="mat_caster"
            friction="0 0 0" priority="1"/>

      <!-- 前滑板：防前翻(翘头) -->
      <geom name="skid_front" type="box" size="0.002 0.002 0.0015"
            pos="0.060 0 -0.01049"
            material="mat_caster"
            friction="0 0 0" priority="1"/>

      <!-- ═══════════════════════════════════════════════════════════
        光电管巡线传感器 — 纯视觉 (contype/conaffinity=0)
        ═══════════════════════════════════════════════════════════ -->
      <!-- 传感器PCB条：厚2mm(X) × 长140mm(Y) × 高1.5mm(Z) -->
      <geom name="sensor_bar" type="box" size="0.002 0.070 0.0015"
            pos="0.040 0 -0.010" material="mat_sensor_bar"
            contype="0" conaffinity="0"/>

      <!-- 16个光电管LED，沿Y轴排列，间距 140mm/15=9.33mm -->
      <geom name="led_00" type="sphere" size="0.001" pos="0.040 -0.070 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_01" type="sphere" size="0.001" pos="0.040 -0.061 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_02" type="sphere" size="0.001" pos="0.040 -0.052 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_03" type="sphere" size="0.001" pos="0.040 -0.042 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_04" type="sphere" size="0.001" pos="0.040 -0.033 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_05" type="sphere" size="0.001" pos="0.040 -0.024 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_06" type="sphere" size="0.001" pos="0.040 -0.014 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_07" type="sphere" size="0.001" pos="0.040 -0.005 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_08" type="sphere" size="0.001" pos="0.040  0.005 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_09" type="sphere" size="0.001" pos="0.040  0.014 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_10" type="sphere" size="0.001" pos="0.040  0.024 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_11" type="sphere" size="0.001" pos="0.040  0.033 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_12" type="sphere" size="0.001" pos="0.040  0.042 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_13" type="sphere" size="0.001" pos="0.040  0.052 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_14" type="sphere" size="0.001" pos="0.040  0.061 -0.011" material="mat_led" contype="0" conaffinity="0"/>
      <geom name="led_15" type="sphere" size="0.001" pos="0.040  0.070 -0.011" material="mat_led" contype="0" conaffinity="0"/>

    </body>

    <!-- WALLS -->
  </worldbody>

  <actuator>
    <!-- 轮毂直驱电机：ctrl 值 = 轮端扭矩 (Nm) -->
    <motor name="motor_L" joint="axle_L" gear="1"/>
    <motor name="motor_R" joint="axle_R" gear="1"/>
  </actuator>

  <sensor>
    <!-- 6轴IMU @ 轮轴中心 -->
    <gyro name="gyro" site="imu_site"/>
    <accelerometer name="accel" site="imu_site"/>

    <!-- 地面真值 (验证用) -->
    <framepos name="pos" objtype="body" objname="chassis"/>
    <framequat name="quat" objtype="body" objname="chassis"/>
    <framelinvel name="linvel" objtype="body" objname="chassis"/>
    <frameangvel name="angvel" objtype="body" objname="chassis"/>

    <!-- 编码器：轮轴角度/角速度 -->
    <jointpos name="enc_L_pos" joint="axle_L"/>
    <jointvel name="enc_L_vel" joint="axle_L"/>
    <jointpos name="enc_R_pos" joint="axle_R"/>
    <jointvel name="enc_R_vel" joint="axle_R"/>
  </sensor>
</mujoco>
